DEBUG=0
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# Set to 1 when the site is served only over HTTPS (e.g. behind nginx / a load balancer)
USE_TLS=0

MYSQL_DATABASE=rent_db
MYSQL_USER=rent_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

DB_HOST=127.0.0.1
DB_PORT=33066

REDIS_URL=redis://127.0.0.1:6379/0
# Optional; defaults to same host as REDIS_URL with database index 1
# CACHE_REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

ALLOWED_HOSTS=localhost,127.0.0.1

# Serve uploaded images via Django (set 1 in Docker; use nginx/S3 in large production)
SERVE_MEDIA=0

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

MAPS_SEARCH_URL=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook endpoint: https://your-domain/stripe/webhook/  event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=
